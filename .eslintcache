/div>\r\n    )\r\n}\r\n\r\nexport default Projects;",{"ruleId":"32","replacedBy":"33"},{"ruleId":"34","replacedBy":"35"},{"ruleId":"36","severity":1,"message":"37","line":6,"column":13,"nodeType":"38","endLine":6,"endColumn":41},{"ruleId":"36","severity":1,"message":"37","line":13,"column":25,"nodeType":"38","endLine":13,"endColumn":49},{"ruleId":"36","severity":1,"message":"37","line":16,"column":25,"nodeType":"38","endLine":16,"endColumn":49},{"ruleId":"36","severity":1,"message":"37","line":19,"column":25,"nodeType":"38","endLine":19,"endColumn":49},{"ruleId":"36","severity":1,"message":"37","line":22,"column":25,"nodeType":"38","endLine":22,"endColumn":49},{"ruleId":"39","severity":1,"message":"40","line":21,"column":29,"nodeType":"38","endLine":21,"endColumn":91},"no-native-reassign",["41"],"no-negated-in-lhs",["42"],"jsx-a11y/anchor-is-valid","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","no-global-assign","no-unsafe-negation"]